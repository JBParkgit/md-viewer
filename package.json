{
  "name": "docuflow",
  "version": "2.17.0",
  "description": "Docuflow - Document Workspace & Editor",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder && node scripts/rename-release.js",
    "build:win": "electron-vite build && electron-builder --win && node scripts/rename-release.js",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.10.9",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.36.3",
    "@uiw/react-codemirror": "^4.25.8",
    "chokidar": "^4.0.3",
    "docx": "^9.6.1",
    "electron-store": "^8.2.0",
    "googleapis": "^171.4.0",
    "html-to-docx": "^1.8.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.2",
    "mermaid": "^11.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-pdf": "^10.4.1",
    "react-syntax-highlighter": "^15.6.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.docuflow.app",
    "productName": "Docuflow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "description": "Markdown Document",
        "role": "Viewer"
      },
      {
        "ext": "markdown",
        "name": "Markdown",
        "description": "Markdown Document",
        "role": "Viewer"
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "md_icon.ico"
    }
  }
}
